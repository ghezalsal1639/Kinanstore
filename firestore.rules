rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "salimgh1639@gmail.com" ||
        request.auth.token.email == "salimgh1639-sys@gmail.com" ||
        request.auth.token.email == "ghezalsal1639@gmail.com"
      );
    }

    function getStatusWeight(status) {
      return status == 'new' ? 0 :
             status == 'confirmed' ? 1 :
             status == 'shipped' ? 2 :
             status == 'delivered' ? 3 :
             status == 'returned' ? 4 : -1;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAuthenticated();
      allow update: if isAdmin() || (
        isAuthenticated() && 
        // Ensure only status is changed and it only moves forward
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        getStatusWeight(request.resource.data.status) > getStatusWeight(resource.data.status)
      );
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /helpers/{helperId} {
      // Helpers need to read the collection to find their own record by email
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
