{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "wilaya": { "type": "string" },
        "commune": { "type": "string" },
        "address": { "type": "string" },
        "deliveryMethod": { "type": "string", "enum": ["home", "office"] },
        "offer": { "type": "string" },
        "flavor": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "confirmed", "shipped", "delivered", "returned"] },
        "totalPrice": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "trackingNumber": { "type": "string" }
      },
      "required": ["customerName", "phone", "wilaya", "commune", "offer", "status", "totalPrice", "date"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "media": { "type": "array", "items": { "type": "string" } },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "media", "date"]
    },
    "Helper": {
      "title": "Helper",
      "description": "A staff member account",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["email", "password"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Application wide settings",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string", "description": "Base64 or URL of the logo" },
        "storeName": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/settings/app": {
      "schema": { "$ref": "#/entities/AppSettings" },
      "description": "Application settings"
    },
    "/helpers/{helperId}": {
      "schema": { "$ref": "#/entities/Helper" },
      "description": "Staff member accounts"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Store products"
    }
  }
}
